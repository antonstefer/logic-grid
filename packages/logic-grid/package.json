{
  "name": "logic-grid",
  "version": "1.0.0",
  "description": "Generate and solve logic grid puzzles (zebra puzzles / Einstein's riddles)",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ bench/",
    "format": "prettier --write src/ bench/",
    "format:check": "prettier --check src/ bench/",
    "test:watch": "vitest",
    "bench": "vitest run --config vitest.bench.ts",
    "bench:profile": "tsup --entry.profile bench/profile.ts --no-dts && node --cpu-prof dist/profile.mjs",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test",
    "prepublishOnly": "npm run check && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "logic-grid",
    "zebra-puzzle",
    "einstein-riddle",
    "constraint-satisfaction",
    "puzzle-generator",
    "puzzle-solver",
    "sat-solver"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/antonstefer/logic-grid.git",
    "directory": "packages/logic-grid"
  },
  "bugs": "https://github.com/antonstefer/logic-grid/issues",
  "homepage": "https://github.com/antonstefer/logic-grid#readme",
  "devDependencies": {}
}
