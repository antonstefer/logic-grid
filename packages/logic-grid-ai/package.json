{
  "name": "logic-grid-ai",
  "version": "1.0.0",
  "description": "AI-powered themed category generation for logic-grid puzzles",
  "keywords": [
    "logic-grid",
    "puzzle",
    "ai",
    "theme-generation",
    "anthropic",
    "zebra-puzzle",
    "einstein-riddle"
  ],
  "homepage": "https://github.com/antonstefer/logic-grid/tree/main/packages/logic-grid-ai#readme",
  "bugs": "https://github.com/antonstefer/logic-grid/issues",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test",
    "prepublishOnly": "npm run check && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "author": "Anton Stefer (https://github.com/antonstefer)",
  "license": "MIT",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/antonstefer/logic-grid.git",
    "directory": "packages/logic-grid-ai"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0"
  },
  "peerDependencies": {
    "logic-grid": "^1.0.0"
  },
  "devDependencies": {}
}
