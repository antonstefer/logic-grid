{
  "name": "logic-grid",
  "version": "1.0.0",
  "description": "Generate and solve logic grid puzzles (zebra puzzles / Einstein's riddles)",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ bench/",
    "format": "prettier --write src/ bench/",
    "format:check": "prettier --check src/ bench/",
    "test:watch": "vitest",
    "bench": "vitest run --config vitest.bench.ts",
    "bench:profile": "tsup --entry.profile bench/profile.ts --no-dts && node --cpu-prof dist/profile.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "logic-grid",
    "zebra-puzzle",
    "einstein-riddle",
    "constraint-satisfaction",
    "puzzle-generator",
    "puzzle-solver",
    "sat-solver"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "tsup": "^8.0.0",
    "typescript": "^5.5.3",
    "vitest": "^3.0.0"
  }
}
